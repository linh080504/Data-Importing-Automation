      "parameters": {
        "jsCode": "return [{ json: { ...$json, log_target: 'workflow_error_log', log_entry: { workflow_step: $json.workflow_step, retryable: $json.retryable, error_message: $json.error_message, record_id: $json.record_id ?? $json.unique_key ?? null } } }];"
      },
      "id": "logWorkflowError",
      "name": "Log Workflow Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, 570]
    }
