                "conditions": [
                  { "leftValue": "={{$json.status}}", "rightValue": "REVIEW", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "review"
            }
          ]
        },
        "options": {}
      },
