    {
      "parameters": {
        "url": "={{$json.source_url}}",
        "options": {}
      },
      "id": "fetchSourceData",
      "name": "Fetch Source Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [640, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const sourceRows = Array.isArray($json.data) ? $json.data : Array.isArray($json.items) ? $json.items : Array.isArray($json) ? $json : [$json];\nconst config = $('Fetch Source Data').item.json;\nreturn sourceRows.map((row, index) => ({\n  json: {\n    job_id: config.job_id,\n    source_id: config.source_id,\n    unique_key: String(row.unique_key ?? row.id ?? `row-${index + 1}`),\n    record_hash: JSON.stringify(row),\n    raw_payload: row,\n    critical_fields_extracted: {},\n    overall_confidence: config.overall_confidence,\n    status: config.status,\n    run_mode: config.run_mode ?? 'MANUAL',\n    refresh_reason: config.refresh_reason ?? null\n  }\n}));"
      },
      "id": "normalizeWebhookPayload",
      "name": "Normalize Webhook Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8000/api/v1/internal/webhook/n8n/upsert-record",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-Secret",
              "value": "={{$env.N8N_WEBHOOK_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "specifyBody": "json",
        "jsonBody": "={{$json}}",
        "options": {}
      },
      "id": "callUpsertWebhook",
      "name": "Call Upsert Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1080, 300],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [
                  { "leftValue": "={{$json.action}}", "rightValue": "SKIP_AI_NO_CHANGE", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "skip"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [
                  { "leftValue": "={{$json.action}}", "rightValue": "UPSERT_APPROVED", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "approved"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [
                  { "leftValue": "={{$json.action}}", "rightValue": "QUEUED_FOR_REVIEW", "operator": { "type": "string", "operation": "equals" } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "review"
            }
          ]
        },
        "options": {}
      },
      "id": "routeWebhookAction",
      "name": "Route Webhook Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1300, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "workflow_status", "value": "SKIPPED_NO_CHANGE" },
            { "name": "message", "value": "Record hash unchanged, AI processing skipped." }
          ]
        }
      },
      "id": "skipNoChange",
      "name": "Skip No Change",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1530, 180]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "workflow_status", "value": "AI_EXTRACTION_PENDING" },
            { "name": "message", "value": "Proceed to AI extraction/judge flow for approved changed record." }
          ]
        }
      },
      "id": "queueAiExtraction",
      "name": "Queue AI Extraction",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1530, 300]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, next_step: 'AI_EXTRACT_CRITICAL_FIELDS', note: 'Placeholder for AI1 extractor call', ai_extraction_status: 'SUCCESS' } }];"
      },
      "id": "aiExtractorPlaceholder",
      "name": "AI Extractor Placeholder",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1750, 300],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 1000,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, next_step: 'AI_JUDGE_VALIDATION', note: 'Placeholder for AI2 judge call and confidence scoring', ai_judge_status: 'SUCCESS' } }];"
      },
      "id": "aiJudgePlaceholder",
      "name": "AI Judge Placeholder",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1970, 300],
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 1000,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [
                  { "leftValue": "={{$json.status}}", "rightValue": "APPROVED", "operator": { "type": "string", "operation": "equals" } }
