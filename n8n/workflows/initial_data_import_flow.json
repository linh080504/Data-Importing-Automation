    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "workflow_status", "value": "QUEUE_MANUAL_REVIEW" },
            { "name": "message", "value": "Backend requested manual review for this changed record." }
          ]
        }
      },
      "id": "backendReviewPath",
      "name": "Backend Review Path",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1530, 420]
    },
    {
      "parameters": {
        "jsCode": "const errorMessage = $json.error?.message ?? '';\nconst workflowStep = !errorMessage ? 'UNKNOWN_STAGE' : errorMessage.includes('127.0.0.1:8000') || errorMessage.includes('/internal/webhook/n8n/upsert-record') ? 'UPSERT_WEBHOOK' : errorMessage.includes('source_url') || errorMessage.includes('status code') || errorMessage.includes('request') ? 'FETCH_SOURCE_DATA' : errorMessage.includes('AI_EXTRACT_CRITICAL_FIELDS') ? 'AI_EXTRACTOR' : errorMessage.includes('AI_JUDGE_VALIDATION') ? 'AI_JUDGE' : 'UNKNOWN_STAGE';\nconst retryable = workflowStep === 'FETCH_SOURCE_DATA' || workflowStep === 'UPSERT_WEBHOOK' || workflowStep === 'AI_EXTRACTOR' || workflowStep === 'AI_JUDGE';\nreturn [{ json: { ...$json, workflow_step: workflowStep, retryable, error_message: errorMessage || 'Unknown workflow error' } }];"
      },
      "id": "classifyWorkflowError",
      "name": "Classify Workflow Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 520]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [
                  { "leftValue": "={{$json.retryable}}", "rightValue": true, "operator": { "type": "boolean", "operation": "true", "singleValue": true } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "review"
            },
            {
              "conditions": {
                "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict", "version": 2 },
                "conditions": [
                  { "leftValue": "={{$json.retryable}}", "rightValue": false, "operator": { "type": "boolean", "operation": "false", "singleValue": true } }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "terminal"
            }
          ]
        },
        "options": {}
      },
      "id": "routeWorkflowError",
      "name": "Route Workflow Error",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [1530, 520]
