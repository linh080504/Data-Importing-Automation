APP_NAME=Data Import Automation API
ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/data_import_automation
GEMINI_API_KEY=your_gemini_api_key_here
N8N_WEBHOOK_SECRET=your_internal_shared_secret_here
N8N_CALLBACK_HEADER=X-N8N-Secret
INTERNAL_WEBHOOK_ENABLED=true
# Browser origins for local Next.js (comma-separated). Leave default for npm run dev on port 3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_NAME=Data Import Automation API
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/data_import_automation

# AI keys (paste NEW keys here; revoke previously exposed keys)

ANTHROPIC_API_KEY=
# Legacy Gemini config compatibility
#GEMINI_MODEL=gemma-4-31b
#GEMINI_FALLBACK_MODELS=

# Extractor: Claude Sonnet
EXTRACTION_PROVIDER=claude
EXTRACTION_MODEL=default
EXTRACTION_ALLOW_FALLBACK=false
EXTRACTION_RETRY_LIMIT=1
EXTRACTION_TIMEOUT_SECONDS=45

# Judge: Claude Opus
JUDGE_PROVIDER=claude
JUDGE_MODEL=default-4-7
JUDGE_ALLOW_FALLBACK=false
JUDGE_RETRY_LIMIT=1
JUDGE_TIMEOUT_SECONDS=45

# Cost / safety guardrails
MAX_AI_CALLS_PER_ROW=2
CRAWL_RESUME_FAILED_ONLY=true

N8N_WEBHOOK_SECRET=
N8N_CALLBACK_HEADER=X-N8N-Secret
INTERNAL_WEBHOOK_ENABLED=true
N8N_ALLOWED_CONTENT_TYPE=application/json

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
