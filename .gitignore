/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/tests/*
# next.js
/.next/*
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.next/
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/backend/.pytest_cache/*
/backend/__pycache__/*
/backend/app/__pycache__/*
