/backend/app/schemas/__pycache__/*
/backend/app/db/__pycache__/*
/backend/app/models/__pycache__/*
/backend/app/routers/__pycache__/*
/backend/app/utils/__pycache__/*
# Node/Javascript
node_modules/
npm-debug.log

# Python (Nếu backend dùng Python)
__pycache__/
venv/
env/

